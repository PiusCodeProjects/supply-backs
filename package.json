{
  "name": "construction-supply-chain",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build --filter=@cscp/types && turbo run build",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:studio": "cd apps/api && npx prisma studio",
    "db:seed": "cd apps/api && npx ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "turbo": "^1.13.4"
  }
}
